# Rust build artifacts
# Note: Cargo.lock is intentionally committed — Olga ships a binary CLI,
# and committed lockfiles guarantee reproducible builds for end users.
/target
**/target/

# Python virtual environments and caches
.venv/
**/.venv/
__pycache__/
**/__pycache__/
.mypy_cache/
.pytest_cache/
.ruff_cache/
*.egg-info/
dist/
build/

# Editors and OS
*.swp
*.swo
*~
.DS_Store
.idea/
.vscode/
*.iml

# MkDocs build output (generated by CI, deployed separately)
site/

# Test corpus (downloaded on demand, not committed)
tests/corpus/**/*.pdf
tests/corpus/**/*.docx
tests/corpus/**/*.xlsx
tests/corpus/**/*.html

# Internal working files (not for public repo)
CLAUDE.md
docs-dev/
